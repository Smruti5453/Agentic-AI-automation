rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scripts
    // Fields: title, content, status, version, clientId, writerId, createdAt, updatedAt, lastFollowUpAt, followUpCount, responseDeadline
    //
    // Collection: clients
    // Fields: name, email, phone, preferredChannel, slaHours
    //
    // Collection: scripts/{scriptId}/logs
    // Fields: scriptId, timestamp, action, message, channel
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "smrutirnrout04@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidScript(data) {
      let required = ['title', 'content', 'status', 'version', 'clientId', 'writerId', 'createdAt', 'updatedAt', 'followUpCount'];
      return hasRequiredFields(data, required) &&
             isValidString(data.title, 1, 200) &&
             isValidString(data.content, 1, 50000) &&
             data.status in ["Ready for Approval", "Waiting for Feedback", "Approved", "Revision Requested", "Rejected", "Escalated", "Call Requested"] &&
             data.version is int && data.version >= 1 &&
             data.clientId is string &&
             data.writerId is string &&
             data.followUpCount is int && data.followUpCount >= 0;
    }

    function isValidClient(data) {
      let required = ['name', 'email', 'phone', 'preferredChannel', 'slaHours'];
      return hasRequiredFields(data, required) &&
             isValidString(data.name, 1, 100) &&
             isValidString(data.email, 5, 100) &&
             isValidString(data.phone, 5, 20) &&
             data.preferredChannel in ["WhatsApp", "Email"] &&
             data.slaHours is int && data.slaHours > 0;
    }

    match /scripts/{scriptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidScript(request.resource.data);
      allow update: if isAuthenticated() && isValidScript(request.resource.data) && 
                    (request.resource.data.writerId == resource.data.writerId || isAdmin());
      allow delete: if isAdmin();

      match /logs/{logId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && 
                      isValidString(request.resource.data.action, 1, 100) &&
                      isValidString(request.resource.data.message, 1, 1000);
      }
    }

    match /clients/{clientId} {
      // PII Protection: Only admins can see all client details. 
      // Writers can see clients they are working with (simplified for this app to all authenticated for now, but hardened)
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidClient(request.resource.data);
      allow update: if isAuthenticated() && isValidClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
